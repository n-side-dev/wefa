# Copy this file to `.env` in the same folder before starting the Django demo.
# The demo settings load `django/demo/.env` automatically at startup.

# Assistant provider used by the demo.
# - `mock`: deterministic local/demo responses, good for development and tests
# - `openai`: real OpenAI-backed recipe generation
WEFA_AI_PROVIDER=mock

# OpenAI API key.
# Required only when `WEFA_AI_PROVIDER=openai`.
OPENAI_API_KEY=

# OpenAI model used by the assistant provider.
# Override this only if you want a different compatible model.
OPENAI_MODEL=gpt-4.1-mini

# Optional path to a PEM CA bundle used to verify TLS certificates when calling OpenAI.
# Leave empty on standard machines.
# Set this if your company proxy or local Python installation requires a custom root CA.
# Example:
# OPENAI_CA_BUNDLE=/Users/you/certs/company-root-ca.pem
OPENAI_CA_BUNDLE=
